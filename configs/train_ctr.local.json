{
  "dataset_config": "configs/datasets/amazon_electronics.json",
  "train_path": "data/AmazonElectronics_x1/train.csv",
  "val_path": "data/AmazonElectronics_x1/test.csv",
  "test_path": "",

  "epochs": 20,
  "batch_size": 1024,
  "lr": 0.001,
  "num_workers": 0,

  "interaction_arch": "dhen",
  "interleave_mode": "int",
  "use_rope": true,
  "rope_base": 10000.0,

  "scheduler": "cosine",
  "scheduler_t_max": 20,
  "scheduler_min_lr": 0.0,
  "scheduler_step_size": 10,
  "scheduler_gamma": 0.9,

  "warmup_epochs": 1,
  "grad_clip_norm": 1.0,
  "nan_guard": true,

  "use_wandb": true,
  "wandb_project": "interformer-repro",
  "wandb_run_name": "local-debug",
  "wandb_entity": "",
  "wandb_log_interval": 50,

  "progress_interval": 10,
  "progress_bar": true,

  "early_stop_patience": 3,
  "early_stop_min_delta": 0.0001,
  "early_stop_metric": "val_logloss",

  "save_metrics_path": "results/local_run.json"
}
